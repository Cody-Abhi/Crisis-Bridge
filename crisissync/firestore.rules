rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: role check ────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users ─────────────────────────────────────────────────────────────
    // Any authenticated user can read profiles (needed for chat/walkie/presence)
    // Users can only write their own profile; admins may also write
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null &&
                      (request.auth.uid == userId || isAdmin());
    }

    // ── Hotels ────────────────────────────────────────────────────────────
    // All authenticated users can read; only admins can write
    match /hotels/{hotelCode} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Incidents (legacy path) ───────────────────────────────────────────
    match /incidents/{incidentId} {
      allow read, write: if request.auth != null;
    }

    // ── Incident History ─────────────────────────────────────────────────
    // Created/updated/deleted by admins when resolving an SOS
    // Readable by all authenticated users (staff need to see their own history)
    match /incident_history/{docId} {
      allow read:   if request.auth != null;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Staff Requests ────────────────────────────────────────────────────
    // Any authenticated user can create a join request
    // Only admins can approve/reject (update/delete)
    match /staff_requests/{requestId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Walkie-Talkie Direct Call Invitations ────────────────────────────
    // Used to ping a specific staff member for a 1-on-1 walkie channel
    match /walkie_calls/{callId} {
      allow read, write: if request.auth != null;
    }
  }
}